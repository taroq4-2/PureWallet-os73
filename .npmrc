# pnpm hoisting rules for React Native / Expo
# Gradle build scripts resolve packages via Node — they must be in the root node_modules.
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*babel*
public-hoist-pattern[]=@react-native*
public-hoist-pattern[]=@expo*

